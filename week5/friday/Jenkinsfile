pipeline {
    agent {
        docker {
            image 'node:20-alpine'
            args '--network=host'
        }
    }
    environment {
        BUILD_DIR  = 'dist'
        APP_NAME   = 'kijanikiosk-payments'
        NEXUS_URL  = 'http://192.168.0.102:8081'
        NEXUS_REPO = 'npm-hosted'
    }
    options {
        timeout(time: 10, unit: 'MINUTES')
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Lint') {
            steps {
                dir('week5/friday/kijanikiosk') {
                    sh 'npm ci'
                    sh 'npm run lint || true'
                }
            }
        }
        stage('Build') {
            steps {
                dir('week5/friday/kijanikiosk') {
                    sh 'npm run build'
                    stash includes: 'dist/**, package.json', name: 'build'
                }
            }
        }
        stage('Verify') {
            parallel {
                stage('Test') {
                    steps {
                        dir('week5/friday/kijanikiosk') {
                            sh 'npm test || true'
                        }
                    }
                }
                stage('Security Audit') {
                    steps {
                        dir('week5/friday/kijanikiosk') {
                            sh 'npm audit --audit-level=high || true'
                        }
                    }
                }
            }
        }
        stage('Archive') {
            steps {
                dir('week5/friday/kijanikiosk') {
                    archiveArtifacts artifacts: 'dist/**', fingerprint: true
                }
            }
        }
        stage('Publish') {
    steps {
        dir('week5/friday/kijanikiosk') {
            withCredentials([usernamePassword(
                credentialsId: 'nexus-credentials',
                usernameVariable: 'NEXUS_USER',
                passwordVariable: 'NEXUS_PASS'
            )]) {
                sh '''
                    apk add --no-cache git 2>/dev/null || true

                    GIT_SHA=$(git rev-parse --short HEAD)
                    VERSION="1.0.${BUILD_NUMBER}-${GIT_SHA}"
                    NEXUS_HOST=$(echo $NEXUS_URL | sed 's|http://||')

                    npm version $VERSION --no-git-tag-version --allow-same-version

                    echo "registry=$NEXUS_URL/repository/$NEXUS_REPO/" > .npmrc
                    echo "//$NEXUS_HOST/repository/$NEXUS_REPO/:username=$NEXUS_USER" >> .npmrc
                    echo "//$NEXUS_HOST/repository/$NEXUS_REPO/:_password=$(echo -n $NEXUS_PASS | base64)" >> .npmrc
                    echo "//$NEXUS_HOST/repository/$NEXUS_REPO/:email=ci@example.com" >> .npmrc
                    echo "//$NEXUS_HOST/repository/$NEXUS_REPO/:always-auth=true" >> .npmrc

                    npm publish --registry $NEXUS_URL/repository/$NEXUS_REPO/

                    rm -f .npmrc
                '''
            }
        }
    }
}
    }
    post {
        always {
            cleanWs()
        }
        success {
            echo " Pipeline succeeded - ${env.APP_NAME} published to Nexus"
        }
        failure {
            echo " Pipeline failed - Check logs for details"
        }
        changed {
            echo " Pipeline status changed from previous run"
        }
    }
}
